<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e"
    android:padding="24dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🦀 Clawd 桌宠" android:textSize="28sp" android:textColor="#fff"
        android:textStyle="bold" android:layout_gravity="center" android:layout_marginTop="16dp"/>

    <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textSize="18sp" android:textColor="#ffcc00"
        android:layout_gravity="center" android:layout_marginTop="16dp"/>

    <TextView android:id="@+id/tvStats" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textSize="14sp" android:textColor="#aaaaaa"
        android:layout_gravity="center" android:layout_marginTop="8dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:layout_marginTop="32dp"
        android:gravity="center">

        <Button android:id="@+id/btnStart" android:layout_width="260dp"
            android:layout_height="56dp" android:text="🦀 启动 Clawd" android:textSize="18sp"
            android:layout_marginBottom="12dp"/>

        <LinearLayout android:layout_width="260dp" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/btnChat" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1" android:text="💬 聊天"
                android:layout_marginEnd="6dp"/>
            <Button android:id="@+id/btnFeed" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1" android:text="🍖 喂食"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="260dp" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="8dp">
            <Button android:id="@+id/btnGame" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1" android:text="✊ 猜拳"
                android:layout_marginEnd="6dp"/>
            <Button android:id="@+id/btnSettings" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1" android:text="⚙️ 设置"
                android:layout_marginStart="6dp"/>
        </LinearLayout>
    </LinearLayout>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="提示：双击螃蟹打开菜单\n长按喂食 · 单击聊天/互动"
        android:textSize="12sp" android:textColor="#666666" android:gravity="center"
        android:layout_gravity="center" android:layout_marginTop="32dp"/>
</LinearLayout>
