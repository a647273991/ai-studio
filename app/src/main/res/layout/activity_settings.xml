<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#1a1a2e" android:padding="24dp">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="⚙️ Clawd 设置" android:textSize="24sp" android:textColor="#fff"
        android:textStyle="bold" android:layout_marginBottom="20dp"/>

    <TextView android:id="@+id/tvStats" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:textSize="14sp" android:textColor="#ffcc00"
        android:background="#222244" android:padding="12dp" android:layout_marginBottom="16dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🤖 AI 模型设置" android:textSize="18sp" android:textColor="#fff"
        android:layout_marginBottom="12dp"/>

    <EditText android:id="@+id/etApiUrl" android:layout_width="match_parent"
        android:layout_height="48dp" android:hint="API URL" android:textSize="14sp"
        android:textColor="#fff" android:textColorHint="#666" android:background="#222244"
        android:padding="12dp" android:inputType="textUri" android:singleLine="true"/>

    <EditText android:id="@+id/etApiKey" android:layout_width="match_parent"
        android:layout_height="48dp" android:hint="API Key" android:textSize="14sp"
        android:textColor="#fff" android:textColorHint="#666" android:background="#222244"
        android:padding="12dp" android:inputType="textPassword" android:singleLine="true"
        android:layout_marginTop="8dp"/>

    <EditText android:id="@+id/etModel" android:layout_width="match_parent"
        android:layout_height="48dp" android:hint="模型名 (如 gpt-4o-mini)" android:textSize="14sp"
        android:textColor="#fff" android:textColorHint="#666" android:background="#222244"
        android:padding="12dp" android:inputType="text" android:singleLine="true"
        android:layout_marginTop="8dp"/>

    <EditText android:id="@+id/etPrompt" android:layout_width="match_parent"
        android:layout_height="120dp" android:hint="系统提示词（性格设定）" android:textSize="14sp"
        android:textColor="#fff" android:textColorHint="#666" android:background="#222244"
        android:padding="12dp" android:inputType="textMultiLine" android:gravity="top"
        android:layout_marginTop="8dp"/>

    <Button android:id="@+id/btnSave" android:layout_width="match_parent"
        android:layout_height="52dp" android:text="💾 保存设置" android:textSize="16sp"
        android:layout_marginTop="20dp"/>

    <Button android:id="@+id/btnResetEmotion" android:layout_width="match_parent"
        android:layout_height="48dp" android:text="🔄 重置情绪数据" android:textSize="14sp"
        android:layout_marginTop="8dp"/>
</LinearLayout>
</ScrollView>
